#!/usr/bin/env bash
# Used to check various aspects
# of the toml file (file, table, value)

# refrences where this script is located,
# useful in sourcing other files from the
# tools lib.
TOML_CHECK_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

source "$TOML_CHECK_DIR/toml_helpers.sh"
source "$TOML_CHECK_DIR/toml_err.sh"

# toml_check_file <file>
# Checks to see if there is a toml file at the given path.
toml_check_file() {
    toml_check_arg_count "$#" 1 || {
	echo "toml_check_file: Invalid argument count $#/1" ; return 6;
    }
    
    local file="$1"
    
    if [[ ! -f "$file" ]]; then
	return 5
    fi
    return 0
}


# toml_check_table <file> <table>
# Checks the given toml file for the desired table
# Returns:
#	0, if success
#	2, if no table
#	5, if no file
#	6, invalid args
toml_check_table() {
    # Validate the number of args
    toml_check_arg_count "$#" 2 || {
	toml_error "toml_check_table: Invalid argument count $#/2" ; return 6;
    }
    
    local file="$1" table="$2"
    
    if ! toml_check_file "$file"; then
	return 5
    fi

    # Check for the table now.
}

# toml_check_key <file> <table> <key>
toml_check_key() {
    toml_check_arg_count "$#" 3 || {
	toml_error "toml_check_table: Invalid argument count $#/3" ; exit 1;
    }

    local file="$1" table="$2" key="$3"

    if ! toml_check_file "$file"; then
	return 5
    fi
    
    if ! toml_check_table "$file" "$table"; then
	return 2
    fi

    # Check for the Key now
}


toml_check_file test.toml ; toml_err_to_str "$?"
toml_check_table test.toml test ; toml_err_to_str $?
toml_check_key test.toml test key ; toml_err_to_str $?
