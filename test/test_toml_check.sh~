#!/usr/bin/env bash
# Used to test the toml check

source ./test_helpers.sh
source ../lib/toml_check.sh
source ../lib/toml_err.sh

echo "Running Toml Check Tests..."

test_check_file() {
    echo "Testing file exists"
    toml_check_file test.toml
    status="$?"
    assert_true "$status" "check file failed with a code $status, should have passed"
    
    echo "Testing file does not exists"
    toml_check_file test.toml
    status="$?"
    assert_eq "$status" "$NO_FILE" "toml_check_file should have exited with 5 but exited with $status"
    
    echo "Testing check file to many args"
    toml_check_file test.toml
    status="$?"
    assert_eq "$status" "$INVALID_ARGS" "check file should fail with to many args."
    
    echo "Testing check file to many args"
    toml_check_file
    status="$?"
    assert_eq "$status" "$INVALID_ARGS" "check file should fail with to few args."

    echo "All check file test passed successfully"
}

