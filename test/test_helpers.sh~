# assert_true <return code> <message>
assert_true() {
    if [[ "$#" -lt 1 || "$#" -gt 2 ]]; then
        exit "$INVALID_ARGS"
    fi
    assert "$1" 0 -eq "$2"
}

# assert_false <return code> <message>
assert_false() {
