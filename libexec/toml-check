#!/usr/bin/env bash
# CLI wrapper for toml_check library functions.

# SOURCE GUARD FOR LIBRARY LOADING
if [[ -v toml_cli_check_sourced ]]; then
    return 0
fi
toml_cli_check_sourced=1

# Name of the main tool
toml_tool_name="toml"
toml_cli_check_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
toml_bin_dir=""
toml_lib_dir=""
toml_libexec_dir=""

if [ "$toml_cli_check_dir" = "$HOME/.local/libexe/$toml_tool_name/" ]; then
    echo ""
elif [ "$toml_cli_check_dir" = "/usr/libexec/$toml_tool_name/" ]; then
     echo ""
else
    toml_error
fi



toml_check_usage() {
    cat <<EOF
Usage:
  toml-check <command> [args]

Commands:
  file <file>                 Check that a TOML file exists and is valid
  table <file> <table>        Check that a table exists
  key <file> <table> <key>    Check that a key exists under a table
  help                        Show this help message

Examples:
  toml-check file config.toml
  toml-check table config.toml project
  toml-check key config.toml project repo
EOF
}

toml_check_cli_file() {
    if [[ "$#" -ne 1 ]]; then
        echo "toml-check file: expected 1 argument"
        toml_check_usage
        return 1
    fi

    toml_check_file "$1"
    return "$?"
}

toml_check_cli_table() {
    if [[ "$#" -ne 2 ]]; then
        echo "toml-check table: expected 2 arguments"
        toml_check_usage
        return 1
    fi

    toml_check_table "$1" "$2"
    return "$?"
}

toml_check_cli_key() {
    if [[ "$#" -ne 3 ]]; then
        echo "toml-check key: expected 3 arguments"
        toml_check_usage
        return 1
    fi

    toml_check_key "$1" "$2" "$3"
    return "$?"
}

main() {
    local cmd="" status=""

    if [[ "$#" -lt 1 ]]; then
        toml_check_usage
        return 1
    fi

    cmd="$1"
    shift

    case "$cmd" in
        file)
            toml_check_cli_file "$@"
            status="$?"
            ;;
        table)
            toml_check_cli_table "$@"
            status="$?"
            ;;
        key)
            toml_check_cli_key "$@"
            status="$?"
            ;;
        help|-h|--help)
            toml_check_usage
            return 0
            ;;
        *)
            echo "Unknown command: $cmd"
            toml_check_usage
            return 1
            ;;
    esac

    if [[ "$status" -eq 0 ]]; then
        echo "Check passed"
    else
        echo "Check failed: $(toml_err_to_str "$status")"
    fi

    return "$status"
}

# only run main when executed, not sourced
if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    main "$@"
fi
