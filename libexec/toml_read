#!/usr/bin/env bash
# CLI wrapper for toml_check library functions.

# SOURCE GUARD FOR LIBRARY LOADING
if [[ -v toml_cli_read_sourced ]]; then
    return 0
fi
toml_cli_read_sourced=1

# Name of the main tool
toml_tool_name="toml"
toml_cli_read_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
toml_tool_bin_dir=""
toml_tool_lib_dir=""

# Resolve install/dev paths
if [[ "${toml_cli_read_dir}" == "${HOME}/.local/libexec/${toml_tool_name}" ]]; then
    [[ -d "${HOME}/.local/lib/${toml_tool_name}" ]] && toml_tool_lib_dir="${HOME}/.local/lib/${toml_tool_name}"
    [[ -d "${HOME}/.local/bin" ]] && toml_tool_bin_dir="${HOME}/.local/bin"

elif [[ "${toml_cli_read_dir}" == "/usr/libexec/${toml_tool_name}" ]]; then
    [[ -d "/usr/lib/${toml_tool_name}" ]] && toml_tool_lib_dir="/usr/lib/${toml_tool_name}"
    [[ -d "/usr/bin" ]] && toml_tool_bin_dir="/usr/bin"

else
    [[ -d "${toml_cli_read_dir}/../lib" ]] && toml_tool_lib_dir="${toml_cli_read_dir}/../lib"
    [[ -d "${toml_cli_read_dir}/../" ]] && toml_tool_bin_dir="${toml_cli_read_dir}/../" 
fi

# Load libraries
source "${toml_tool_lib_dir}/internal/toml_err.bash"
source "${toml_tool_lib_dir}/internal/toml_read.bash"
source "${toml_tool_lib_dir}/internal/toml_helpers.bash"
source "${toml_tool_lib_dir}/cli_helpers/source_externs.bash"

if ! source_style; then
    echo "Failed to source Style properly"
fi

toml_read_version="0.1.0"

toml_table=""
toml_key=""
toml_file=""

toml_read_usage_style() {
        helpmenu_print_title "Toml Read"
        helpmenu_print_subtitle "Read values from a TOML file"
        helpmenu_print_header "Usage"
        helpmenu_print_option "toml read [opts] <file>" ""
        helpmenu_print_header "Options"
        helpmenu_print_option "-h, --help, help" "Show this help message"
        helpmenu_print_option "-v, --version" "Print the version of this subcommand"
        helpmenu_print_option "-t, --table <table>" "Read from a specific table"
        helpmenu_print_option "-k, --key <key>" "Read a specific key (use with --table for nested)"
        helpmenu_print_option "-e, --error <value>" "Print the error message for a given code"
        helpmenu_print_header "Examples"
        helpmenu_print_example "toml" "read config.toml"
        helpmenu_print_example "toml" "read -t foo config.toml"
        helpmenu_print_example "toml" "read -k bar config.toml"
        helpmenu_print_example "toml" "read -k bar -t foo config.toml"
        helpmenu_print_example "toml" "read -t foo -k bar config.toml"
}

toml_read_usage() {
    cat <<'EOF'
Toml Read
Read values from a TOML file

Usage:
    toml read [opts] <file>

Options:
    -h, --help, help            Show this help message
    -v, --version               Print the version of this subcommand
    -t, --table <table>         Read from a specific table
    -k, --key <key>             Read a specific key (use with --table for nested)
    -e, --error <value>         Print the error message for a given code

Examples:
    toml read config.toml
    toml read -t foo config.toml
    toml read -k bar config.toml
    toml read -k bar -t foo config.toml
    toml read -t foo -k bar config.toml
EOF
}


toml_read_show_usage() {
    if command -v style >/dev/null 2>&1; then
        toml_read_usage_style
    else
        toml_read_usage
    fi
}

toml_read_parse_args() {
    toml_table=""
    toml_key=""
    toml_file=""

    while [[ "$#" -gt 0 ]]; do
        case "$1" in
            -h|--help|help)
                toml_read_show_usage
                exit 0
                ;;

            -v|--version)
                echo "Toml Read Version: $toml_read_version"
                exit 0
                ;;

	    -e|--error)
		if [[ -z "${2:-}" ]]; then
		    toml_error "--error requires an argument"
		    exit "$TOML_INVALID_ARGS"
		fi
		toml_err_to_str "$2"
		exit 0
		;;

	    -t|--table)
		if [[ -z "${2:-}" ]]; then
                    toml_error "--table requires an argument"
                    return "$TOML_INVALID_ARGS"
                fi
                toml_table="$2"
                shift 2
                ;;

            -k|--key)
                if [[ -z "${2:-}" ]]; then
                    toml_error "--key requires an argument"
                    return "$TOML_INVALID_ARGS"
                fi
                toml_key="$2"
                shift 2
                ;;

            --)
                shift
                while [[ "$#" -gt 0 ]]; do
                    if [[ -n "$toml_file" ]]; then
                        toml_error "Only one file may be provided"
                        return "$TOML_INVALID_ARGS"
                    fi
                    toml_file="$1"
                    shift
                done
                ;;

            -*)
                toml_error "Unknown option: $1"
                return "$TOML_INVALID_ARGS"
                ;;

            *)
                if [[ -n "$toml_file" ]]; then
                    toml_error "Only one file may be provided"
                    return "$TOML_INVALID_ARGS"
                fi
                toml_file="$1"
                shift
                ;;
        esac
    done

    if [[ -z "$toml_file" ]]; then
        toml_error "A TOML file is required"
	toml_read_show_usage
        exit "$TOML_INVALID_ARGS"
    fi

    return "$TOML_SUCCESS"
}


toml_read_main() {
    local status=""
    
    toml_read_parse_args "$@"
    if [[ -n "$toml_table" && -n "$toml_key" ]]; then
	toml_read_key "$toml_file" "$toml_table" "$toml_key"
	status="$?"
	exit "$status"
	
    elif [[ -n "$toml_key" && -z "$toml_table" ]]; then
	 toml_log "Not currently implemented"
	 toml_log "TODO: implement a function in lib/toml_read.bash"
	 toml_log "which will print out every instance of a key regardless of table"
	 exit "$status"
	 
    elif [[ -n "$toml_table" && -z "$toml_key" ]]; then
	toml_read_table "$toml_file" "$toml_table"
	status="$?"
	exit "$status"
	
    else
	[[ -z "$toml_file" ]] && { echo "wow how did we get this far with no toml file? weird..."; exit 1; }
	toml_read_file "$toml_file"
	status="$?"
        exit "$status"
    fi
}

# only run main when executed, not sourced
if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    toml_read_main "$@"
fi
