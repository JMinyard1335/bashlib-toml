#!/usr/bin/env bash

## DO NOT REMOVE THE FOLLOWING SECTION
## READ IT UNDERSTAND IT FEEL IT IN YOUR BONES.
##
## The following section is used to determine how to source in the rest of
## the project. It does this by looking at its location and using that info to find its
## libexec/ and lib/ folder. It warns the user if no (lib, libexec) dirs are found. if the
## user tries to source something with these and they do not exist it will fail.

toml_tool_path="$(realpath -- "$0")"						# Path to tool script including the script
toml_tool_bin_dir="$(dirname -- "$toml_tool_path")"		# Path to tool script minus the script.
toml_tool_name="$(basename -- "$0")"					# the name of the tool you just executed.
toml_tool_lib_dir=""										# Path to lib/ dir based off tool location
toml_tool_libexec_dir=""									# Path to libexec/ dir based off tool location

if [[ "${toml_tool_path}" = "${HOME}/.local/bin/${toml_tool_name}" ]]; then		# Checks locally 
    [[ -d "${HOME/}.local/lib/${toml_tool_name}" ]]  && toml_tool_lib_dir="${HOME}/.local/lib/${toml_tool_name}";
    [[ -d "${HOME}/.local/libexec/${toml_tool_name}" ]]  && toml_tool_libexec_dir="${HOME}/.local/libexec/${toml_tool_name}";

elif [[ "$toml_tool_bin_dir" = "/usr/bin/" ]]; then    # Checks globally.
    [[ -d "/usr/lib/${toml_tool_name}" ]]  && toml_tool_lib_dir="/usr/lib/$toml_tool_name";
    [[ -d "/usr/libexec/${toml_tool_name}" ]]  && toml_tool_libexec_dir="/usr/libexec/$toml_tool_name";

else	# Check for the other files in the same dir as the tool (repo/source project.)
    [[ -d "${toml_tool_bin_dir}/lib" ]]  && toml_tool_lib_dir="$toml_tool_bin_dir/lib"
    [[ -d "${toml_tool_bin_dir}/libexec" ]]  && toml_tool_libexec_dir="$toml_tool_bin_dir/libexec";
fi


# Pull in the tool libraries.
source "${toml_tool_lib_dir}/internal/toml_err.bash"
source "${toml_tool_lib_dir}/internal/toml_helpers.bash"
source "${toml_tool_lib_dir}/cli_helpers/source_externs.bash"

toml_style_help_available=0
if source_style >/dev/null 2>&1 && \
   declare -F helpmenu_print_title >/dev/null 2>&1 && \
   declare -F helpmenu_print_subtitle >/dev/null 2>&1 && \
   declare -F helpmenu_print_header >/dev/null 2>&1 && \
   declare -F helpmenu_print_option >/dev/null 2>&1; then
    toml_style_help_available=1
fi

## and that is how you can source the files for tools that will rely on other files elsewhere.
## If there is a better way id be happy to know. 
## End of Section

toml_command=""			# The command that will be run.

_toml_main_valid_command() {
    case "$1" in
        read|check|install|remove|update) return 0 ;;
        *) return 1 ;;
    esac
}

_toml_main_usage_style() {
    helpmenu_print_title "Toml"
    helpmenu_print_subtitle "A bash CLI tool for reading toml"
    helpmenu_print_header "Usage"
    helpmenu_print_option "toml <command> <args>" ""
    helpmenu_print_header "Commands"
    helpmenu_print_option "install" "Installs this tool to the system"
    helpmenu_print_option "remove" "removes this tool from the system"
    helpmenu_print_option "update" "updates this tool from its repo"
    helpmenu_print_option "check" "checks if something exists in a toml file"
    helpmenu_print_option "read" "reads values from a toml file"
    helpmenu_print_header "Examples"
    helpmenu_print_example "toml check " "tool.toml"
    helpmenu_print_example "toml check " "-t project tool.toml"
    helpmenu_print_example "toml check " "-t project -k tool tool.toml"
    helpmenu_print_example "toml read " "tool.toml"
    helpmenu_print_example "toml read " "-t project tool.toml"
    helpmenu_print_example "toml read " "-t project -k tool tool.toml"
    helpmenu_print_example "toml read " "--help"
}

_toml_main_usage() {
    cat <<'EOF'
Toml
A bash CLI tool for reading toml

Usage:
    toml <command> <args>

Commands:
    install                     Installs this tool to the system
    remove                      Removes this tool from the system
    update                      Updates this tool from its repo
    check                       Checks if something exists in a toml file
    read                        Reads values from a toml file

Examples:
    toml check tool.toml
    toml check -t project tool.toml
    toml check -t project -k tool tool.toml
    toml read tool.toml
    toml read -t project tool.toml
    toml read -t project -k tool tool.toml
    toml read --help
EOF
        return 0
    
}

_toml_main_print_usage() {
    if [[ "$toml_style_help_available" -eq 1 ]]; then
        _toml_main_usage_style
    else
        _toml_main_usage
    fi
}

_toml_main_parse_args() {
    [[ $# -eq 0 ]] && {
        _toml_main_print_usage
        exit 1
    }

    case "$1" in
        -h|--help|help)
	    _toml_main_print_usage
	    exit 0
            ;;
        *)
            if _toml_main_valid_command "$1"; then
                COMMAND="$1"
                shift
            else
                printf '\e[31m[Error]\e[0m: unknown command: %s\n' "$1" >&2
                _toml_main_print_usage
                exit 1
            fi
            ;;
    esac

    ARGS=("$@")
}

# Checks to see if my installer command is installed.
# all install, update and remove logic will be regliated
# to the installer.
toml_cli_check_for_installer() {
    local rc="$(which installer)"
    if [[ -z "$rc" ]]; then
	return 1
    fi
    return 0
}

toml_cli_install() {
    if ! toml_cli_check_for_installer; then
	toml_error "Installer not found!"
	echo "My installer is need for this feature to work. It can be found over at:"
	echo -e "\t\e[36mhttps://github.com/JMinyard1335/Bash-Installer\e[0m"
	echo "It will handle all the installations, updates, and removal of my tools."
	echo "If you want an option to just install it from the CLI go to github check for an issue"
	echo "if and only if there is not an issue and you dont see it in the change logs then open one."
	exit 1
    fi

    installer install "$toml_tool_bin_dir"
}

toml_cli_update() {
    if ! toml_cli_check_for_installer; then
	toml_error "Installer not found!"
	echo "My installer is need for this feature to work. It can be found over at:"
	echo -e "\t\e[36mhttps://github.com/JMinyard1335/Bash-Installer\e[0m"
	echo "It will handle all the installations, updates, and removal of my tools."
	echo "If you want an option to just install it from the CLI go to github check for an issue"
	echo "if and only if there is not an issue and you dont see it in the change logs then open one."
	exit 1
    fi

    installer update "$toml_tool_name"
}

toml_cli_remove() {
    if ! toml_cli_check_for_installer; then
	toml_error "Installer not found!"
	echo "My installer is need for this feature to work. It can be found over at:"
	echo -e "\t\e[36mhttps://github.com/JMinyard1335/Bash-Installer\e[0m"
	echo "It will handle all the installations, updates, and removal of my tools."
	echo "If you want an option to just install it from the CLI go to github check for an issue"
	echo "if and only if there is not an issue and you dont see it in the change logs then open one."
	exit 1
    fi

    installer  remove "$toml_tool_name"
}

toml_cli_main() {

    _toml_main_parse_args "$@"
    case "$COMMAND" in
	"check") bash "${toml_tool_libexec_dir}/toml_check" "${ARGS[@]}";;
	"read") bash "${toml_tool_libexec_dir}/toml_read" "${ARGS[@]}";;
	"install")  toml_cli_install;;
	"update") toml_cli_update;;
	"remove") toml_cli_remove;;
	*) toml_error "Unknown command read please try again with --help";;
    esac
    
}

toml_cli_main "$@"
